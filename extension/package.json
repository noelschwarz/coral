{
  "name": "coral-extension",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint . --max-warnings 0",

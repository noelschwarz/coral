{
  "manifest_version": 3,
  "name": "Coral (dev)",
  "version": "0.1.0",
  "description": "Coral session capture — development scaffold (see coral-engineering-spec.md).",
  "action": {
    "default_title": "Coral",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["http://127.0.0.1/*"]
}
